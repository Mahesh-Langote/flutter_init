      {{else if flags.isGetX}}
      final success = await Get.find<AuthController>().forgotPassword(
        context: context, 
        email: emailController.text,
      );
      if (success && context.mounted) {
        {{#if (eq flags.routerPackage "go_router")}}
        context.go(AppRoutes.login);
        {{else if (eq flags.routerPackage "auto_route")}}
        context.replaceRoute(const LoginRoute());
        {{else}}
        Navigator.pushReplacementNamed(context, AppRoutes.login);
        {{/if}}
      }
      {{else}}
      {{#if flags.usesFlutterHooks}}
      isLoadingState.value = true;
      {{/if}}
      try {
        final result = await AuthService.instance.forgotPassword(
          email: emailController.text.trim(),
        );

        result.fold(
          (failure) {
            showToast(context, message: failure.message, status: 'error');
