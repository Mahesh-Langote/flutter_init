                  style: tt.headlineMedium?.copyWith(fontWeight: FontWeight.bold),
                ).animate().fadeIn().slideY(begin: 0.2),

                SizedBox(height: {{res 'AppSpacing.sm' 'h' flags.usesScreenutil}}),

                Text(
                  {{#if flags.supportsLocalization}}'auth.forgot_password_subtitle'.tr(){{else}}'Enter your email to receive a reset link'{{/if}},
                  style: tt.bodyMedium?.copyWith(color: cs.onSurfaceVariant),
                  textAlign: TextAlign.center,
                ).animate().fadeIn(delay: 200.milliseconds).slideY(begin: 0.2),
                
                SizedBox(height: {{res 'AppSpacing.xxl' 'h' flags.usesScreenutil}}),
                
                // Form Card
                Container(
