{{#if flags.usesFlutterHooks}}
{{#if flags.isRiverpod}}
class ForgotPasswordScreen extends HookConsumerWidget {
{{else}}
class ForgotPasswordScreen extends HookWidget {
{{/if}}
  const ForgotPasswordScreen({super.key});

{{#if flags.isRiverpod}}
  @override
  Widget build(BuildContext context, WidgetRef ref) {
{{else}}
  @override
  Widget build(BuildContext context) {
{{/if}}
    final theme = Theme.of(context);
    final colorScheme = theme.colorScheme;
    final textTheme = theme.textTheme;

    final GlobalKey<FormState> formKey =
        useMemoized(() => GlobalKey<FormState>());
    final emailController = useTextEditingController();
{{#if flags.isRiverpod}}
    final isLoading = ref.watch(authControllerProvider);
    final String? errorMessage = null; // Error handled by snackbar in Controller
{{else if flags.isBloc}}
    final isLoading = context.select((AuthBloc bloc) => bloc.state.isLoading);
    final errorMessage = context.select((AuthBloc bloc) => bloc.state.errorMessage);
{{else if flags.isProvider}}
    final isLoading = context.select((AuthProvider p) => p.isLoading);
    final errorMessage = context.select((AuthProvider p) => p.errorMessage);
{{else if flags.isGetX}}
    final AuthController authController = Get.find<AuthController>();
    final isLoadingState = useStream(authController.isLoading.stream);
    final isLoading = isLoadingState.data ?? false;
    final errorMessageState = useStream(authController.errorMessage.stream);
    final errorMessage = errorMessageState.data;
{{else}}
    final isLoadingState = useState(false);
    final errorMessageState = useState<String?>(null);
    final isLoading = isLoadingState.value;
    final errorMessage = errorMessageState.value;
{{/if}}
    final isSuccess = useState(false);

    Future<void> onContinue() async {
      if (formKey.currentState?.validate() ?? false) {
        {{#if flags.isRiverpod}}
        {{else if flags.isBloc}}
        {{else if flags.isProvider}}
        {{else if flags.isGetX}}
        {{else}}
        isLoadingState.value = true;
        errorMessageState.value = null;
        {{/if}}
        isSuccess.value = false;

        try {
          // Trigger logic based on chosen state management option
          {{#if flags.isRiverpod}}
          bool success = await ref.read(authControllerProvider.notifier).forgotPassword(context: context, email: emailController.text);
          {{else if flags.isBloc}}
          context.read<AuthBloc>().add(ForgotPasswordRequested(context: context, email: emailController.text));
          bool success = true;
          {{else if flags.isProvider}}
          bool success = await context.read<AuthProvider>().forgotPassword(context: context, email: emailController.text);
          {{else if flags.isGetX}}
          bool success = await Get.find<AuthController>().forgotPassword(context: context, email: emailController.text);
          {{else if flags.isMobX}}
          bool success = await context.read<AuthStore>().forgotPassword(context: context, email: emailController.text);
          {{else}}
          await Future.delayed(const Duration(seconds: 2));
          bool success = true;
          {{/if}}

          if (success && context.mounted) {
            isSuccess.value = true;
          }
        } catch (e) {
          {{#if flags.isRiverpod}}
          {{else if flags.isBloc}}
          {{else if flags.isProvider}}
          {{else if flags.isGetX}}
          {{else}}
          errorMessageState.value = e.toString();
          {{/if}}
        } finally {
          if (context.mounted) {
            {{#if flags.isRiverpod}}
            {{else if flags.isBloc}}
            {{else if flags.isProvider}}
            {{else if flags.isGetX}}
            {{else}}
            isLoadingState.value = false;
            {{/if}}
          }
        }
      }
    }

    return _ForgotPasswordView(
      formKey: formKey,
      emailController: emailController,
      isLoading: isLoading,
      errorMessage: errorMessage,
      isSuccess: isSuccess.value,
      onContinue: onContinue,
    );
  }
}
{{else}}
{{#if flags.isRiverpod}}
class ForgotPasswordScreen extends ConsumerStatefulWidget {
  const ForgotPasswordScreen({super.key});

  @override
  ConsumerState<ForgotPasswordScreen> createState() => _ForgotPasswordScreenState();
}

class _ForgotPasswordScreenState extends ConsumerState<ForgotPasswordScreen> {
{{else}}
class ForgotPasswordScreen extends StatefulWidget {
  const ForgotPasswordScreen({super.key});

  @override
  State<ForgotPasswordScreen> createState() => _ForgotPasswordScreenState();
}

class _ForgotPasswordScreenState extends State<ForgotPasswordScreen> {
{{/if}}
  final GlobalKey<FormState> _formKey = GlobalKey<FormState>();
  late final TextEditingController _emailController;
{{#unless flags.isRiverpod}}
{{#unless flags.isBloc}}
{{#unless flags.isProvider}}
{{#unless flags.isGetX}}
{{#unless flags.isMobX}}
  bool _isLoading = false;
  String? _errorMessage;
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
  bool _isSuccess = false;

  @override
  void initState() {
    super.initState();
    _emailController = TextEditingController();
  }

  @override
  void dispose() {
    _emailController.dispose();
    super.dispose();
  }

  Future<void> _onContinue() async {
    if (_formKey.currentState?.validate() ?? false) {
      {{#if flags.isRiverpod}}
      {{else if flags.isBloc}}
      {{else if flags.isProvider}}
      {{else if flags.isGetX}}
      {{else}}
      setState(() {
        _isLoading = true;
        _errorMessage = null;
      });
      {{/if}}
      setState(() => _isSuccess = false);

      try {
        // Trigger logic based on chosen state management option
        {{#if flags.isRiverpod}}
        bool success = await ref.read(authControllerProvider.notifier).forgotPassword(context: context, email: _emailController.text);
        {{else if flags.isBloc}}
        context.read<AuthBloc>().add(ForgotPasswordRequested(context: context, email: _emailController.text));
        bool success = true;
        {{else if flags.isProvider}}
        bool success = await context.read<AuthProvider>().forgotPassword(context: context, email: _emailController.text);
        {{else if flags.isGetX}}
        bool success = await Get.find<AuthController>().forgotPassword(context: context, email: _emailController.text);
        {{else if flags.isMobX}}
        bool success = await context.read<AuthStore>().forgotPassword(context: context, email: _emailController.text);
        {{else}}
        await Future.delayed(const Duration(seconds: 2));
        bool success = true;
        {{/if}}

        if (success && mounted) {
          setState(() => _isSuccess = true);
        }
      } catch (e) {
        {{#if flags.isRiverpod}}
        {{else if flags.isBloc}}
        {{else if flags.isProvider}}
        {{else if flags.isGetX}}
        {{else}}
        if (mounted) {
          setState(() => _errorMessage = e.toString());
        }
        {{/if}}
      } finally {
        if (mounted) {
          {{#if flags.isRiverpod}}
          {{else if flags.isBloc}}
          {{else if flags.isProvider}}
          {{else if flags.isGetX}}
          {{else}}
          setState(() => _isLoading = false);
          {{/if}}
        }
      }
    }
  }

  @override
  Widget build(BuildContext context) {
{{#if flags.isRiverpod}}
    final isLoading = ref.watch(authControllerProvider);
    final String? errorMessage = null;
{{else if flags.isBloc}}
    final isLoading = context.select((AuthBloc bloc) => bloc.state.isLoading);
    final errorMessage = context.select((AuthBloc bloc) => bloc.state.errorMessage);
{{else if flags.isProvider}}
    final isLoading = context.select((AuthProvider p) => p.isLoading);
    final errorMessage = context.select((AuthProvider p) => p.errorMessage);
{{else if flags.isGetX}}
    final AuthController authController = Get.find<AuthController>();
    final isLoading = authController.isLoading.value;
    final errorMessage = authController.errorMessage.value;
{{else}}
    final isLoading = _isLoading;
    final errorMessage = _errorMessage;
{{/if}}

    return _ForgotPasswordView(
      formKey: _formKey,
      emailController: _emailController,
      isLoading: isLoading,
      errorMessage: errorMessage,
      isSuccess: _isSuccess,
      onContinue: _onContinue,
    );
  }
}
{{/if}}

class _ForgotPasswordView extends StatelessWidget {
  const _ForgotPasswordView({
    required this.formKey,
    required this.emailController,
    required this.isLoading,
    required this.errorMessage,
    required this.isSuccess,
    required this.onContinue,
  });

  final GlobalKey<FormState> formKey;
  final TextEditingController emailController;
  final bool isLoading;
  final String? errorMessage;
  final bool isSuccess;
  final VoidCallback onContinue;

  @override
  Widget build(BuildContext context) {
    final theme = Theme.of(context);
    final colorScheme = theme.colorScheme;
    final textTheme = theme.textTheme;

    return Scaffold(
      backgroundColor: colorScheme.surface,
      appBar: AppTopBar(title: {{#if flags.supportsLocalization}}'auth.forgot_password_title'.tr(){{else}}'Forgot Password'{{/if}},
      ),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: EdgeInsets.symmetric(horizontal: {{res 'AppSpacing.lg' 'w' flags.usesScreenutil}}),
          child: Form(
            key: formKey,
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.stretch,
            children: [
              SizedBox(height: {{res 'AppSpacing.xl' 'h' flags.usesScreenutil}}),
              
              // Title
              Text(
                {{#if flags.supportsLocalization}}'auth.forgot_password_title'.tr(){{else}}'Forgot Password'{{/if}},
                textAlign: TextAlign.center,
                style: textTheme.headlineMedium?.copyWith(
                  fontWeight: FontWeight.w800,
                  color: colorScheme.onSurface,
                  fontSize: {{res 28 'sp' flags.usesScreenutil}},
                ),
              ),
              SizedBox(height: {{res 'AppSpacing.sm' 'h' flags.usesScreenutil}}),
              
              // Subtitle
              Padding(
                padding: EdgeInsets.symmetric(horizontal: {{res 'AppSpacing.lg' 'w' flags.usesScreenutil}}),
                child: Text(
                  {{#if flags.supportsLocalization}}'auth.forgot_password_subtitle'.tr(){{else}}'Enter your email address to receive a reset link\nand regain access to your account.'{{/if}},
                  textAlign: TextAlign.center,
                  style: textTheme.bodyMedium?.copyWith(
                    color: colorScheme.onSurfaceVariant,
                    height: 1.5,
                    fontSize: {{res 14 'sp' flags.usesScreenutil}},
                  ),
                ),
              ),
              SizedBox(height: {{res 40 'h' flags.usesScreenutil}}),
              
              // Email Field
              AppTextField(
                controller: emailController,
                enabled: !isLoading && !isSuccess,
                hint: {{#if flags.supportsLocalization}}'auth.email_address'.tr(){{else}}'Email address'{{/if}},
                keyboardType: TextInputType.emailAddress,
                prefixIcon: const Icon(
                  {{#if flags.usesIconsaxPlus}}
                  IconsaxPlusLinear.sms,
                  {{else if flags.usesFlutterRemix}}
                  FlutterRemix.mail_line,
                  {{else if flags.usesHugeicons}}
                  HugeIcons.strokeRoundedMail01,
                  {{else}}
                  Icons.email_outlined,
                  {{/if}}
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return {{#if flags.supportsLocalization}}'auth.email_required'.tr(){{else}}'Email is required'{{/if}};
                  }
                  if (!value.isEmail) {
                    return {{#if flags.supportsLocalization}}'auth.email_invalid'.tr(){{else}}'Enter a valid email'{{/if}};
                  }
                  return null;
                },
              ),
              SizedBox(height: {{res 32 'h' flags.usesScreenutil}}),
              
              // Status Messages
              if (errorMessage != null)
                Padding(
                  padding: EdgeInsets.only(bottom: {{res 'AppSpacing.md' 'h' flags.usesScreenutil}}),
                  child: Text(
                    errorMessage!,
                    style: textTheme.bodyMedium?.copyWith(color: colorScheme.error),
                    textAlign: TextAlign.center,
                  ),
                ),
              if (isSuccess)
                Padding(
                  padding: EdgeInsets.only(bottom: {{res 'AppSpacing.md' 'h' flags.usesScreenutil}}),
                  child: Text(
                    {{#if flags.supportsLocalization}}'auth.reset_link_sent'.tr(){{else}}'Password reset link sent to your email.'{{/if}},
                    style: textTheme.bodyMedium?.copyWith(
                      color: Theme.of(context).extension<AppColorsExtension>()?.success ?? Colors.green,
                    ),
                    textAlign: TextAlign.center,
                  ),
                ),

              // Continue Button
              AppButton(
                label: isSuccess
                    ? ({{#if flags.supportsLocalization}}'shared.back_button'.tr(){{else}}'Back to Login'{{/if}})
                    : ({{#if flags.supportsLocalization}}'shared.continue_button'.tr(){{else}}'Continue'{{/if}}),
                onPressed: isLoading
                    ? null
                    : (isSuccess
                        ? () {
                            if (Navigator.canPop(context)) {
                              Navigator.pop(context);
                            }
                          }
                        : onContinue),
                isLoading: isLoading,
                variant: ButtonVariant.primary,
                height: ButtonSize.large,
                isFullWidth: true,
              ),
            ],
          ),
          ),
        ),
      ),
    );
  }
}
