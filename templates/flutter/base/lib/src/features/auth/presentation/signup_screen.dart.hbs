      } finally {
        if (mounted) {
          {{#if flags.isRiverpod}}
          {{else if flags.isBloc}}
          {{else if flags.isProvider}}
          {{else if flags.isGetX}}
          {{else}}
          setState(() => _isLoading = false);
          {{/if}}
