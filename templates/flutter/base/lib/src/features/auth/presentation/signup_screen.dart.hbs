class _SignupView extends StatelessWidget {
  const _SignupView({
    required this.formKey,
    required this.nameController,
    required this.emailController,
    required this.passwordController,
    required this.confirmPasswordController,
    required this.obscurePassword,
    required this.obscureConfirmPassword,
    required this.isLoading,
    required this.errorMessage,
    required this.onToggleObscurePassword,
    required this.onToggleObscureConfirmPassword,
    required this.onSignUp,
    required this.onSignIn,
  });

  final GlobalKey<FormState> formKey;
  final TextEditingController nameController;
  final TextEditingController emailController;
  final TextEditingController passwordController;
  final TextEditingController confirmPasswordController;
  final bool obscurePassword;
  final bool obscureConfirmPassword;
  final bool isLoading;
  final String? errorMessage;
  final VoidCallback onToggleObscurePassword;
  final VoidCallback onToggleObscureConfirmPassword;
  final VoidCallback onSignUp;
  final VoidCallback onSignIn;

  @override
  Widget build(BuildContext context) {
    final theme = context.theme;
    final colorScheme = theme.colorScheme;
    final textTheme = theme.textTheme;

    return Scaffold(
      backgroundColor: colorScheme.surface,
      appBar: AppTopBar(title: {{#if flags.supportsLocalization}}'auth.create_account'.tr(){{else}}'Create Account'{{/if}},),
      body: SafeArea(
        child: SingleChildScrollView(
          padding: EdgeInsets.symmetric(horizontal: {{res 'AppSpacing.lg' 'w' flags.usesScreenutil}}),
          child: Form(
            key: formKey,
            child: Column(
              crossAxisAlignment: CrossAxisAlignment.stretch,
            children: [
              SizedBox(height: {{res 'AppSpacing.xl' 'h' flags.usesScreenutil}}),
              
              // Title
              Text(
                {{#if flags.supportsLocalization}}'auth.create_account'.tr(){{else}}'Create Account'{{/if}},
                textAlign: TextAlign.center,
                style: textTheme.headlineMedium?.copyWith(
                  fontWeight: FontWeight.w800,
                  color: colorScheme.onSurface,
                  fontSize: {{res 28 'sp' flags.usesScreenutil}},
                ),
              ),
              SizedBox(height: {{res 'AppSpacing.sm' 'h' flags.usesScreenutil}}),
              
              // Subtitle
              Padding(
                padding: EdgeInsets.symmetric(horizontal: {{res 'AppSpacing.lg' 'w' flags.usesScreenutil}}),
                child: Text(
                  {{#if flags.supportsLocalization}}'auth.create_account_subtitle'.tr(){{else}}'Create a new account to get started and enjoy\nseamless access to our features.'{{/if}},
                  textAlign: TextAlign.center,
                  style: textTheme.bodyMedium?.copyWith(
                    color: colorScheme.onSurfaceVariant,
                    height: 1.5,
                    fontSize: {{res 14 'sp' flags.usesScreenutil}},
                  ),
                ),
              ),
              SizedBox(height: {{res 32 'h' flags.usesScreenutil}}),
              
              // Name Field
              AppTextField(
                controller: nameController,
                enabled: !isLoading,
                hint: {{#if flags.supportsLocalization}}'auth.name'.tr(){{else}}'Name'{{/if}},
                keyboardType: TextInputType.name,
                prefixIcon: const Icon(
                  {{#if flags.usesIconsaxPlus}}
                  IconsaxPlusLinear.user,
                  {{else if flags.usesFlutterRemix}}
                  FlutterRemix.user_line,
                  {{else if flags.usesHugeicons}}
                  HugeIcons.strokeRoundedUser,
                  {{else}}
                  Icons.person_outline,
                  {{/if}}
                ),
                validator: (value) {
                  if (value == null || value.trim().isEmpty) {
                    return {{#if flags.supportsLocalization}}'auth.name_required'.tr(){{else}}'Name is required'{{/if}};
                  }
                  return null;
                },
              ),
              SizedBox(height: {{res 'AppSpacing.lg' 'h' flags.usesScreenutil}}),
              
              // Email Field
              AppTextField(
                controller: emailController,
                enabled: !isLoading,
                hint: {{#if flags.supportsLocalization}}'auth.email_address'.tr(){{else}}'Email address'{{/if}},
                keyboardType: TextInputType.emailAddress,
                prefixIcon: const Icon(
                  {{#if flags.usesIconsaxPlus}}
                  IconsaxPlusLinear.sms,
                  {{else if flags.usesFlutterRemix}}
                  FlutterRemix.mail_line,
                  {{else if flags.usesHugeicons}}
                  HugeIcons.strokeRoundedMail01,
                  {{else}}
                  Icons.email_outlined,
                  {{/if}}
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return {{#if flags.supportsLocalization}}'auth.email_required'.tr(){{else}}'Email is required'{{/if}};
                  }
                  if (!value.isEmail) {
                    return {{#if flags.supportsLocalization}}'auth.email_invalid'.tr(){{else}}'Enter a valid email'{{/if}};
                  }
                  return null;
                },
              ),
              SizedBox(height: {{res 'AppSpacing.lg' 'h' flags.usesScreenutil}}),
              
              // Password Field
              AppTextField(
                controller: passwordController,
                enabled: !isLoading,
                hint: {{#if flags.supportsLocalization}}'auth.password'.tr(){{else}}'Password'{{/if}},
                obscureText: obscurePassword,
                prefixIcon: const Icon(
                  {{#if flags.usesIconsaxPlus}}
                  IconsaxPlusLinear.lock,
                  {{else if flags.usesFlutterRemix}}
                  FlutterRemix.lock_line,
                  {{else if flags.usesHugeicons}}
                  HugeIcons.strokeRoundedLock01,
                  {{else}}
                  Icons.lock_outline,
                  {{/if}}
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return {{#if flags.supportsLocalization}}'auth.password_required'.tr(){{else}}'Password is required'{{/if}};
                  }
                  if (value.length < 6) {
                    return {{#if flags.supportsLocalization}}'auth.password_too_short'.tr(){{else}}'Password must be at least 6 characters'{{/if}};
                  }
                  return null;
                },
                suffixIcon: IconButton(
                  icon: Icon(
                    {{#if flags.usesIconsaxPlus}}
                    obscurePassword ? IconsaxPlusLinear.eye_slash : IconsaxPlusLinear.eye,
                    {{else if flags.usesFlutterRemix}}
                    obscurePassword ? FlutterRemix.eye_off_line : FlutterRemix.eye_line,
                    {{else if flags.usesHugeicons}}
                    obscurePassword ? HugeIcons.strokeRoundedViewOff : HugeIcons.strokeRoundedView,
                    {{else}}
                    obscurePassword ? Icons.visibility_off_outlined : Icons.visibility_outlined,
                    {{/if}}
                    color: colorScheme.onSurfaceVariant,
                  ),
                  onPressed: onToggleObscurePassword,
                ),
              ),
              SizedBox(height: {{res 'AppSpacing.lg' 'h' flags.usesScreenutil}}),
              
              // Confirm Password Field
              AppTextField(
                controller: confirmPasswordController,
                enabled: !isLoading,
                hint: {{#if flags.supportsLocalization}}'auth.confirm_password'.tr(){{else}}'Confirm Password'{{/if}},
                obscureText: obscureConfirmPassword,
                prefixIcon: const Icon(
                  {{#if flags.usesIconsaxPlus}}
                  IconsaxPlusLinear.lock,
                  {{else if flags.usesFlutterRemix}}
                  FlutterRemix.lock_line,
                  {{else if flags.usesHugeicons}}
                  HugeIcons.strokeRoundedLock01,
                  {{else}}
                  Icons.lock_outline,
                  {{/if}}
                ),
                validator: (value) {
                  if (value == null || value.isEmpty) {
                    return {{#if flags.supportsLocalization}}'auth.confirm_password_required'.tr(){{else}}'Confirm password is required'{{/if}};
                  }
                  if (value != passwordController.text) {
                    return {{#if flags.supportsLocalization}}'auth.passwords_do_not_match'.tr(){{else}}'Passwords do not match'{{/if}};
                  }
                  return null;
                },
                suffixIcon: IconButton(
                  icon: Icon(
                    {{#if flags.usesIconsaxPlus}}
                    obscureConfirmPassword ? IconsaxPlusLinear.eye_slash : IconsaxPlusLinear.eye,
                    {{else if flags.usesFlutterRemix}}
                    obscureConfirmPassword ? FlutterRemix.eye_off_line : FlutterRemix.eye_line,
                    {{else if flags.usesHugeicons}}
                    obscureConfirmPassword ? HugeIcons.strokeRoundedViewOff : HugeIcons.strokeRoundedView,
                    {{else}}
                    obscureConfirmPassword ? Icons.visibility_off_outlined : Icons.visibility_outlined,
                    {{/if}}
                    color: colorScheme.onSurfaceVariant,
                  ),
                  onPressed: onToggleObscureConfirmPassword,
                ),
              ),
              SizedBox(height: {{res 32 'h' flags.usesScreenutil}}),
              
              // Error Message
              if (errorMessage != null)
                Padding(
                  padding: EdgeInsets.only(bottom: {{res 'AppSpacing.md' 'h' flags.usesScreenutil}}),
                  child: Text(
                    errorMessage!,
                    style: textTheme.bodyMedium?.copyWith(color: colorScheme.error),
                    textAlign: TextAlign.center,
                  ),
                ),

              // SignUp Button
              AppButton(
                label: {{#if flags.supportsLocalization}}'auth.create_account_button'.tr(){{else}}'Create Account'{{/if}},
                onPressed: isLoading ? null : onSignUp,
                isLoading: isLoading,
                variant: ButtonVariant.primary,
                height: ButtonSize.large,
                isFullWidth: true,
              ),
              SizedBox(height: {{res 'AppSpacing.xl' 'h' flags.usesScreenutil}}),
              
              // Sign In Link
              Center(
                child: InkWell(
                  onTap: onSignIn,
                  child: RichText(
                    text: TextSpan(
                      text: {{#if flags.supportsLocalization}}'auth.already_have_account'.tr(){{else}}'Already have an account? '{{/if}},
                      style: textTheme.bodyMedium?.copyWith(
                        color: colorScheme.onSurfaceVariant,
                        fontWeight: FontWeight.w500,
                      ),
                      children: [
                        TextSpan(
                          text: {{#if flags.supportsLocalization}}'auth.sign_in_here'.tr(){{else}}'Sign In here'{{/if}},
                          style: textTheme.bodyMedium?.copyWith(
                            color: colorScheme.primary,
                            fontWeight: FontWeight.w700,
                          ),
                        ),
                      ],
                    ),
                  ),
                ),
              ),
              SizedBox(height: {{res 'AppSpacing.xl' 'h' flags.usesScreenutil}}),
              
              // Divider text
              Row(
                children: [
                  const Expanded(child: AppDivider()),
                  Padding(
                    padding: EdgeInsets.symmetric(horizontal: {{res 'AppSpacing.md' 'w' flags.usesScreenutil}}),
                    child: Text(
                      {{#if flags.supportsLocalization}}'auth.or_continue_with'.tr(){{else}}'Or Continue With Account'{{/if}},
                      style: textTheme.labelSmall?.copyWith(
                        color: colorScheme.onSurfaceVariant,
                        fontWeight: FontWeight.w500,
                      ),
                    ),
                  ),
                  const Expanded(child: AppDivider()),
                ],
              ),
              SizedBox(height: {{res 'AppSpacing.xl' 'h' flags.usesScreenutil}}),
              
              // Social Buttons
              Row(
                mainAxisAlignment: MainAxisAlignment.center,
                children: [
                  _SocialButton(
                    onTap: () {},
                    iconData: Icons.facebook,
                    iconColor: const Color(0xFF1877F2),
                  ),
                  SizedBox(width: {{res 'AppSpacing.md' 'w' flags.usesScreenutil}}),
                  // Emulate Google G icon using text for generic material 
                  _SocialButton(
                    onTap: () {},
                    child: Text(
                      'G',
                      style: TextStyle(
                        fontSize: {{res 22 'sp' flags.usesScreenutil}},
                        fontWeight: FontWeight.w900,
                        color: Colors.red, // normally multicolored, simplified here
                      ),
                    ),
                  ),
                  SizedBox(width: {{res 'AppSpacing.md' 'w' flags.usesScreenutil}}),
                  _SocialButton(
                    onTap: () {},
                    iconData: Icons.apple,
                    iconColor: colorScheme.onSurface,
                  ),
                ],
              ),
              SizedBox(height: {{res 'AppSpacing.xxl' 'h' flags.usesScreenutil}}),
            ],
          ),
          ),
        ),
      ),
    );
  }
}

class _SocialButton extends StatelessWidget {
  final VoidCallback onTap;
  final IconData? iconData;
  final Color? iconColor;
  final Widget? child;

  const _SocialButton({
    required this.onTap,
    this.iconData,
    this.iconColor,
    this.child,
  });

  @override
  Widget build(BuildContext context) {
    return InkWell(
      onTap: onTap,
      borderRadius: BorderRadius.circular(50),
      child: Container(
        height: {{res 48 'h' flags.usesScreenutil}},
        width: {{res 48 'w' flags.usesScreenutil}},
        decoration: BoxDecoration(
          color: context.theme.colorScheme.surface,
          shape: BoxShape.circle,
          boxShadow: [
            BoxShadow(
              color: Colors.black.withOpacity(0.05),
              blurRadius: 10,
              offset: const Offset(0, 4),
            ),
          ],
        ),
        alignment: Alignment.center,
        child: child ??
            Icon(
              iconData,
              size: {{res 24 'sp' flags.usesScreenutil}},
              color: iconColor,
            ),
      ),
    );
  }
}
