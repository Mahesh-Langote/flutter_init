class SignupScreen extends HookWidget {
{{/if}}
  const SignupScreen({super.key});

{{#if flags.isRiverpod}}
  @override
  Widget build(BuildContext context, WidgetRef ref) {
{{else}}
  @override
  Widget build(BuildContext context) {
{{/if}}

    final GlobalKey<FormState> formKey =
        useMemoized(() => GlobalKey<FormState>());
    final nameController = useTextEditingController();
    final emailController = useTextEditingController();
    final passwordController = useTextEditingController();
    final confirmPasswordController = useTextEditingController();
    final obscurePassword = useState(true);
    final obscureConfirmPassword = useState(true);
{{#if flags.isRiverpod}}
    final isLoading = ref.watch(authControllerProvider);
    final String? errorMessage = null; // Error handled by snackbar in Controller
{{else if flags.isBloc}}
    final isLoading = context.select((AuthBloc bloc) => bloc.state.isLoading);
    final errorMessage = context.select((AuthBloc bloc) => bloc.state.errorMessage);
{{else if flags.isProvider}}
    final isLoading = context.select((AuthProvider p) => p.isLoading);
    final errorMessage = context.select((AuthProvider p) => p.errorMessage);
{{else if flags.isGetX}}
    final AuthController authController = Get.find<AuthController>();
    final isLoadingState = useStream(authController.isLoading.stream);
    final isLoading = isLoadingState.data ?? false;
    final errorMessageState = useStream(authController.errorMessage.stream);
    final errorMessage = errorMessageState.data;
{{else}}
    final isLoadingState = useState(false);
    final errorMessageState = useState<String?>(null);
    final isLoading = isLoadingState.value;
    final errorMessage = errorMessageState.value;
{{/if}}

    Future<void> onSignUp() async {
      if (formKey.currentState?.validate() ?? false) {
        {{#if flags.isRiverpod}}
        {{else if flags.isBloc}}
        {{else if flags.isProvider}}
        {{else if flags.isGetX}}
        {{else}}
        isLoadingState.value = true;
        errorMessageState.value = null;
        {{/if}}

        try {
          // Trigger logic based on chosen state management option
          {{#if flags.isRiverpod}}
          await ref.read(authControllerProvider.notifier).signUp(context: context, name: nameController.text, email: emailController.text, password: passwordController.text);
          {{else if flags.isBloc}}
          context.read<AuthBloc>().add(SignUpRequested(context: context, name: nameController.text, email: emailController.text, password: passwordController.text));
          {{else if flags.isProvider}}
          await context.read<AuthProvider>().signUp(context: context, name: nameController.text, email: emailController.text, password: passwordController.text);
          {{else if flags.isGetX}}
          await Get.find<AuthController>().signUp(context: context, name: nameController.text, email: emailController.text, password: passwordController.text);
          {{else if flags.isMobX}}
          await context.read<AuthStore>().signUp(context: context, name: nameController.text, email: emailController.text, password: passwordController.text);
          {{else}}
          await Future.delayed(const Duration(seconds: 2));
          if (context.mounted) {
            {{#if (eq flags.routerPackage "go_router")}}
            context.go(AppRoutes.home);
            {{else if (eq flags.routerPackage "auto_route")}}
            context.replaceRoute(const HomeRoute());
            {{else}}
            Navigator.pushReplacementNamed(context, AppRoutes.home);
            {{/if}}
          }
          {{/if}}
        } catch (e) {
          {{#if flags.isRiverpod}}
          {{else if flags.isBloc}}
          {{else if flags.isProvider}}
          {{else if flags.isGetX}}
          {{else}}
          errorMessageState.value = e.toString();
          {{/if}}
        } finally {
          if (context.mounted) {
            {{#if flags.isRiverpod}}
            {{else if flags.isBloc}}
            {{else if flags.isProvider}}
            {{else if flags.isGetX}}
            {{else}}
            isLoadingState.value = false;
            {{/if}}
          }
        }
      }
    }

    void onSignIn() {
      // Navigate back to login
      if (Navigator.canPop(context)) {
        Navigator.pop(context);
      } else {
        {{#if (eq flags.routerPackage "go_router")}}
        context.pushReplacement(AppRoutes.login);
        {{else if (eq flags.routerPackage "auto_route")}}
        context.replaceRoute(const LoginRoute());
        {{else}}
        Navigator.pushReplacementNamed(context, AppRoutes.login);
        {{/if}}
      }
    }

    return _SignupView(
      formKey: formKey,
      nameController: nameController,
      emailController: emailController,
      passwordController: passwordController,
      confirmPasswordController: confirmPasswordController,
      obscurePassword: obscurePassword.value,
      obscureConfirmPassword: obscureConfirmPassword.value,
      isLoading: isLoading,
      errorMessage: errorMessage,
      onToggleObscurePassword: () => obscurePassword.value = !obscurePassword.value,
      onToggleObscureConfirmPassword: () => obscureConfirmPassword.value = !obscureConfirmPassword.value,
      onSignUp: onSignUp,
      onSignIn: onSignIn,
    );
  }
}
