{{#if flags.usesScreenutil}}
export 'package:flutter_screenutil/flutter_screenutil.dart';
{{/if}}
{{#if flags.isRiverpod}}
export 'package:flutter_riverpod/flutter_riverpod.dart' hide describeIdentity, shortHash;
{{/if}}
{{#if flags.isProvider}}
export 'package:provider/provider.dart';
{{/if}}
{{#if flags.isBloc}}
export 'package:flutter_bloc/flutter_bloc.dart';
{{/if}}
{{#if flags.isGetX}}
export 'package:get/get.dart';
{{/if}}
{{#if flags.routerPackage}}
export 'package:{{flags.routerPackage}}/{{flags.routerPackage}}.dart';
{{/if}}
{{#if flags.usesDio}}
export 'package:dio/dio.dart';
{{/if}}
{{#if flags.usesCachedNetworkImage}}
export 'package:cached_network_image/cached_network_image.dart';
{{/if}}
{{#if flags.usesFlutterSvg}}
