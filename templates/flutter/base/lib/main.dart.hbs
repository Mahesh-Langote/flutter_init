import 'src/imports/imports.dart';
{{#if (eq backend.provider "firebase")}}
import 'package:firebase_core/firebase_core.dart';
{{/if}}
{{#if (eq backend.provider "supabase")}}
import 'package:supabase_flutter/supabase_flutter.dart';
{{/if}}
{{#if extras.flavors}}
import 'src/flavors.dart';
{{/if}}
import 'src/app.dart';

Future<void> main() async {
  WidgetsFlutterBinding.ensureInitialized();
  {{#if flags.supportsLocalization}}
  await EasyLocalization.ensureInitialized();
  {{/if}}
  {{#if flags.usesDotenv}}
  await dotenv.load(fileName: '.env');
  {{/if}}
  {{#if extras.flavors}}
  FlavorConfig.load(Flavor.dev);
  {{/if}}
  {{#if (eq backend.provider "firebase")}}
  await Firebase.initializeApp();
  {{/if}}
  {{#if (eq backend.provider "supabase")}}
  await Supabase.initialize(
    {{#if flags.usesDotenv}}
    url: dotenv.get('SUPABASE_URL', fallback: 'https://YOUR-PROJECT.supabase.co'),
    anonKey: dotenv.get('SUPABASE_ANON_KEY', fallback: 'YOUR-ANON-KEY'),
    {{else}}
    url: const String.fromEnvironment(
      'SUPABASE_URL',
      defaultValue: 'https://YOUR-PROJECT.supabase.co',
    ),
    anonKey: const String.fromEnvironment(
      'SUPABASE_ANON_KEY',
      defaultValue: 'YOUR-ANON-KEY',
    ),
    {{/if}}
  );
  {{/if}}
  {{#if (eq backend.provider "appwrite")}}
  AuthService.instance.init(
    {{#if flags.usesDotenv}}
    endpoint: dotenv.get('APPWRITE_ENDPOINT', fallback: 'https://cloud.appwrite.io/v1'),
    projectId: dotenv.get('APPWRITE_PROJECT_ID', fallback: 'your-project-id'),
    {{else}}
    endpoint: const String.fromEnvironment(
      'APPWRITE_ENDPOINT',
      defaultValue: 'https://cloud.appwrite.io/v1',
    ),
    projectId: const String.fromEnvironment(
      'APPWRITE_PROJECT_ID',
      defaultValue: 'your-project-id',
    ),
    {{/if}}
  );
  {{/if}}

  runApp(
    LocalizationWrapper(
      child: StateWrapper(
        child: const App(),
      ),
    ),
  );
}