import 'src/imports/imports.dart';
{{#if (eq backend.provider "firebase")}}
import 'package:firebase_core/firebase_core.dart';
{{/if}}
{{#if extras.flavors}}
import 'src/flavors.dart';
{{/if}}
import 'src/app.dart';

Future<void> main() async {
  WidgetsFlutterBinding.ensureInitialized();
  {{#if flags.supportsLocalization}}
  await EasyLocalization.ensureInitialized();
  {{/if}}
  {{#if flags.usesDotenv}}
  await dotenv.load(fileName: '.env');
  {{/if}}
  {{#if extras.flavors}}
  FlavorConfig.load(Flavor.dev);
  {{/if}}
  {{#if (eq backend.provider "firebase")}}
  await Firebase.initializeApp();
  {{/if}}

  {{#if flags.isRiverpod}}
  runApp(
    {{#if flags.supportsLocalization}}
    EasyLocalization(
      supportedLocales: const [{{#each flags.supportedLocales}}Locale('{{this}}'),{{/each}}],
      path: 'assets/translations',
      fallbackLocale: const Locale('{{flags.fallbackLocale}}'),
      child: const ProviderScope(child: App()),
    )
    {{else}}
    const ProviderScope(child: App())
    {{/if}}
  );
  {{else}}
  runApp(
    {{#if flags.supportsLocalization}}
    EasyLocalization(
      supportedLocales: const [{{#each flags.supportedLocales}}Locale('{{this}}'),{{/each}}],
      path: 'assets/translations',
      fallbackLocale: const Locale('{{flags.fallbackLocale}}'),
      child: const App(),
    )
    {{else}}
    const App()
    {{/if}}
  );
  {{/if}}
}